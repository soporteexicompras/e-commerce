# ── Dependencias (se instalan dentro del container) ──
node_modules
vendor
/public/build
/public/hot
/public/storage
/public/fonts-manifest.dev.json

# ── Storage runtime (se monta como volumen) ─────────
/storage/framework/cache
/storage/framework/sessions
/storage/framework/views
/storage/framework/testing
/storage/framework/pail
/storage/logs
/storage/app/public
/storage/*.key

# ── Entorno y secretos ─────────────────────────────
.env
.env.backup
.env.production
