auth.json

# ── Tests y artefactos ─────────────────────────────
/tests/coverage
*.log
*.swp
*.tmp
Thumbs.db
.DS_Store
Homestead.json
Homestead.yaml

# ── Documentación (no se copia al container) ───────
*.md
!README.md
LICENSE
CONTRIBUTING.md

# ── Docker (no recursión infinita) ─────────────────
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore
docker/

# ── DB local de dev ────────────────────────────────
/database/database.sqlite
/database/*.sqlite
