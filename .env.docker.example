# ════════════════════════════════════════════════════════════════════════════
#  Exicompras — .env para Docker
#  Uso:  cp .env.docker.example .env  y luego editar APP_KEY y secretos
# ════════════════════════════════════════════════════════════════════════════

APP_NAME="Exicompras"
APP_ENV=production
APP_KEY=                              # se genera automáticamente en el primer arranque
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

# ── Hosts de los servicios (coinciden con docker-compose.yml) ──
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=exicompras
DB_USERNAME=exicompras
DB_PASSWORD=cambia-esto-en-produccion
DB_ROOT_PASSWORD=cambia-esto-en-produccion

# ── Redis (cache + sesiones + colas) ──
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ── Logging ──
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ── Storage ──
FILESYSTEM_DISK=public
BROADCAST_CONNECTION=log

# ── Mail (SMTP o servicio externo) ──
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@exicompras.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Flags del container ──
#   true  = corre `php artisan migrate --force` en cada arranque del app
#   false = no toca la BD (recomendado en prod, usa migraciones manuales)
RUN_MIGRATIONS=false

# ── Puertos publicados en el host ──
HTTP_PORT=8080
HTTPS_PORT=443
DB_PORT=3306

# ── AWS S3 (opcional, para producción) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Aimeos (opcional) ──
# Personalización de tema vía mshop_locale_site.config['theme/default']
