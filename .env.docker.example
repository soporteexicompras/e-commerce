# ════════════════════════════════════════════════════════════════════════════
#  Exicompras — .env para Docker / Coolify
#  Uso local:  cp .env.docker.example .env  y luego editar APP_KEY y secretos
#  En Coolify: inyectar las variables desde el dashboard (Environment Variables)
# ════════════════════════════════════════════════════════════════════════════

APP_NAME="Exicompras"
APP_ENV=production
APP_KEY=                              # se genera automáticamente en el primer arranque
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_CO                # Colombia (no es_ES)

# ── Dominio público (informativo; Coolify lo gestiona en su dashboard) ──
# APP_DOMAIN=shop.exicompras.com      # usado solo si necesitas un fallback manual

# ── Hosts de los servicios (coinciden con docker-compose.yml) ──
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=exicompras
DB_USERNAME=exicompras
DB_PASSWORD=cambia-esto-en-produccion
DB_ROOT_PASSWORD=cambia-esto-en-produccion

# ── Redis (cache + sesiones + colas) ──
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ── Logging ──
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ── Storage ──
FILESYSTEM_DISK=public
BROADCAST_CONNECTION=log

# ── Mail (SMTP o servicio externo) ──
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@exicompras.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Flags del container (entrypoint.sh) ──
#   RUN_MIGRATIONS=true   = corre `php artisan migrate --force` y `aimeos:setup`
#                          en cada arranque del app container. Útil para
#                          CI/CD o primer deploy. Desactivar tras el primer
#                          deploy exitoso si prefieres control manual.
#   RUN_SEEDERS=true      = corre los seeders idempotentes de Exicompras
#                          (categorias y productos de Artistas, Influencers,
#                          Coleccionistas) en cada arranque.
RUN_MIGRATIONS=false
RUN_SEEDERS=true

# ── Coolify v4.x (no tocar; Coolify las inyecta vía API) ──
# COOLIFY_URL=https://coolify.tu-dominio.com
# COOLIFY_FQDN=shop.exicompras.com
# COOLIFY_BRANCH=main

# ── AWS S3 (opcional, para producción) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Aimeos (opcional) ──
# Personalización de tema vía mshop_locale_site.config['theme/default']
